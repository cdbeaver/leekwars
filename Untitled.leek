// This is a very basic example:

// We equip the pistol
setWeapon(WEAPON_PISTOL) // Warning: costs 1 TP

// We get the nearest enemy
var enemy = getNearestEnemy()

// We move toward the enemy
moveToward(enemy)

// We try to shoot it!
useWeapon(enemy)